# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-here

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-key
AWS_SECRET_ACCESS_KEY=your-secret
DYNAMODB_TABLE_PREFIX=remit_

# AWS Bedrock
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# FX Rate API
FX_API_KEY=your-fx-api-key
FX_API_BASE_URL=https://v6.exchangerate-api.com/v6

# CoinGecko
COINGECKO_API_BASE_URL=https://api.coingecko.com/api/v3

# Wise Sandbox
WISE_API_BASE_URL=https://api.sandbox.transferwise.tech
WISE_CLIENT_ID=your-wise-client-id
WISE_CLIENT_SECRET=your-wise-client-secret
WISE_REDIRECT_URI=http://localhost:8000/wise/callback

# App
APP_ENV=development
LOG_LEVEL=INFO
RATE_CHECK_INTERVAL_MINUTES=15
