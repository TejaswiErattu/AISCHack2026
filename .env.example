# Database
DATABASE_URL=sqlite:///./terralend.db

# NOAA Climate Data API
NOAA_API_KEY=your_noaa_api_key_here

# AWS Bedrock (Claude AI)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# Application Mode
# Set to true to use mock data for all external APIs (NOAA, Bedrock)
# Ensures demo works fully offline with zero external dependencies
DEMO_MODE=true
